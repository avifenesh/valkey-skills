{
  "name": "valkey-cache-layer-example",
  "version": "1.0.0",
  "description": "Cache-aside layer for Node.js CRUD API using Valkey GLIDE",
  "main": "dist/cache-layer.js",
  "types": "dist/cache-layer.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch usage-example.ts",
    "start": "node dist/usage-example.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "valkey",
    "cache",
    "glide",
    "cache-aside",
    "crud",
    "nodejs",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@valkey/valkey-glide": "^2.3.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/coverage-v8": "^1.1.0",
    "eslint": "^8.56.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
